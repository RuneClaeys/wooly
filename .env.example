# Postgres connection string used by Drizzle and @vercel/postgres.
# Example: postgres://USER:PASSWORD@HOST:5432/DB_NAME
POSTGRES_URL=postgres://postgres:postgres@localhost:5432/wooly

DB_HOST=localhost
DB_PORT=5432
DB_USER=wooly_user
DB_PASSWORD=wooly_password
DB_NAME=wooly


# Nuxt Auth (Auth.js)
# Use a long random string. Generate one with:
# openssl rand -base64 32
AUTH_SECRET=replace-with-a-long-random-secret

# Auth endpoint base URL used by @sidebase/nuxt-auth.
# Keep the /api/auth suffix for local development.
AUTH_ORIGIN=http://localhost:3000/api/auth

# Google OAuth credentials (Google Cloud Console)
GOOGLE_AUTH_CLIENT_ID=your-google-client-id
GOOGLE_AUTH_CLIENT_SECRET=your-google-client-secret
